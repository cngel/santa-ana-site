generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model price {
  id                  Int    @id @default(autoincrement())
  matricula           Float?
  propina             Float?
  manual              Float?
  cartao              Float?
  uniforme_puniv      Float?
  uniforme_enfermagem Float?
}
